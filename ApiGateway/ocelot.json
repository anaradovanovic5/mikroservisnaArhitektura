{
  "Routes": [
    {
      "DownstreamPathTemplate": "/Dogadjaji/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7001
        }
      ],
      "UpstreamPathTemplate": "/api/dogadjaji/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "CacheOptions": {
        "TtlSeconds": 15,
        "Region": "dogadjaji-region"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "10s",
        "Limit": 5,
        "ClientWhitelist": []
      }
    },
    {
      "DownstreamPathTemplate": "/Lokacije/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7002
        }
      ],
      "UpstreamPathTemplate": "/api/lokacije/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "CacheOptions": {
        "TtlSeconds": 15,
        "Region": "lokacije-region"
      }
    },
    {
      "DownstreamPathTemplate": "/Prijave/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7003
        }
      ],
      "UpstreamPathTemplate": "/api/prijave/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "SecurityOptions": {
        "IPAllowedList": [],
        "IPBlockedList": []
      }
    },
    {
      "DownstreamPathTemplate": "/Predavaci/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7003
        }
      ],
      "UpstreamPathTemplate": "/api/predavaci/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7000",
    "RateLimitOptions": {
      "QuotaExceededMessage": "Previse zahteva. Pokusajte ponovo kasnije.",
      "HttpStatusCode": 429
    }
  }
}